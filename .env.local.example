# Pi Seller Kit — environment variables
# Copy this file to ".env.local" and fill in the values, then restart `npm run dev`.
# Never commit .env.local. Only NEXT_PUBLIC_* values reach the browser.

# --- Supabase ---------------------------------------------------------------
# Project URL and keys from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses Row Level Security. NEVER expose this to the client and
# never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Pi Network -------------------------------------------------------------
# Server API key from the Pi Developer Portal. Used only in /api/pi/* routes.
PI_API_KEY=your-pi-server-api-key

# Set to "true" for Pi Sandbox builds, "false" (or unset) for production.
NEXT_PUBLIC_PI_SANDBOX=true
